# Copy to .env and fill in values. Never commit .env.

SECRET_KEY=change_me
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/group_travel_os

# OAuth — redirect URIs must match API_PUBLIC_URL exactly (see oauth_service / Meta / Google console)
FRONTEND_URL=https://group-travel-os.vercel.app
# Brevo (transactional email) — https://app.brevo.com/settings/keys/api
# If unset, verification/reset links are printed to the API logs (dev).
BREVO_API_KEY=your-brevo-api-key-here
FROM_EMAIL=noreply@travello.app
FROM_NAME=Travello
API_PUBLIC_URL=http://localhost:8000
# Local dev example:
# FRONTEND_URL=http://localhost:3000
# Production example (Vercel app + Cloud Run API):
# FRONTEND_URL=https://group-travel-os.vercel.app
# API_PUBLIC_URL=https://group-travel-os-api-704551807369.asia-south1.run.app
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Email verification (SMTP) — required for send/resend verification mail
# Leave unset to disable sending (API returns 503; users can still register).
# Gmail: use an App Password, not your normal password — https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=your@gmail.com
# How long the link in the email stays valid (hours)
EMAIL_VERIFICATION_TOKEN_HOURS=48

# Travello AI (primary engine) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Travello AI (fallback engine) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenWeatherMap — https://home.openweathermap.org/api_keys
OPENWEATHER_API_KEY=your_key_here

# SerpAPI — Google Events and Google Places (Explorer enrichment)
SERPAPI_KEY=your_serpapi_key_here

# Explorer APIs — populate with your developer keys (.env — never commit)
TICKETMASTER_API_KEY=
EVENTBRITE_TOKEN=
YELP_API_KEY=
YOUTUBE_API_KEY=
GOOGLE_PLACES_API_KEY=
APIFY_TOKEN=
# Optional — only if APIFY_TOKEN is set and actor is deployed
APIFY_EXPLORER_ACTOR_ID=

# Stripe — https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here
STRIPE_PRO_PRICE_ID=price_your_id_here

# Frontend (Next.js) — copy to frontend/.env.local (Next only loads env from /frontend)
# NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
# NEXT_PUBLIC_TICKETMASTER_KEY=
# NEXT_PUBLIC_EVENTBRITE_TOKEN=
# NEXT_PUBLIC_PREDICTHQ_TOKEN=
# NEXT_PUBLIC_FIREBASE_* (see Firebase console web app config)
